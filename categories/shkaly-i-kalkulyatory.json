          "max": 7
        },
        {
          "id": "w5",
          "text": "Ажитация",
          "max": 7
        },
        {
          "id": "w6",
          "text": "Тактильные нарушения",
          "max": 7
        },
        {
          "id": "w7",
          "text": "Слуховые нарушения",
          "max": 7
        },
        {
          "id": "w8",
          "text": "Зрительные нарушения",
          "max": 7
        },
        {
          "id": "w9",
          "text": "Головная боль",
          "max": 7
        },
        {
          "id": "w10",
          "text": "Нарушения ориентировки",
          "max": 4
        }
      ],
      "scoring": [
        {
          "range": [
            0,
            8
          ],
          "label": "Лёгкая",
          "color": "#00ff41",
