      "items": [
        {
          "id": "a1",
          "text": "ОБЛИЧЧЯ: моргання, рухи чола, гримаси",
          "max": 4
        },
        {
          "id": "a2",
          "text": "ГУБИ: сморщування, надування, причмокування",
          "max": 4
        },
        {
          "id": "a3",
          "text": "ЩЕЛЕПА: жування, бічні рухи, стискання",
          "max": 4
        },
        {
          "id": "a4",
          "text": "ЯЗИК: хореоатетоїдні рухи, висовування, тремор",
          "max": 4
        },
        {
          "id": "a5",
          "text": "ВЕРХНІ КІНЦІВКИ: хореоатетоїдні рухи пальців, рук",
          "max": 4
        },
        {
          "id": "a6",
          "text": "НИЖНІ КІНЦІВКИ: бічні рухи колін, постукування стоп",
          "max": 4
        },
        {
          "id": "a7",
          "text": "ТУЛУБ: розгойдування, скручування, рухи тазом",
          "max": 4
        },
        {
          "id": "a8",
          "text": "ЗАГАЛЬНА ТЯЖКІСТЬ рухів (глобальна оцінка клініциста)",
          "max": 4
        },
        {
          "id": "a9",
          "text": "ПОРУШЕННЯ ФУНКЦІОНУВАННЯ (мовлення, їжа, самообслуговування)",
          "max": 4
        },
        {
          "id": "a10",
          "text": "УСВІДОМЛЕННЯ пацієнтом (0=ні, 4=тяжкий дистрес)",
          "max": 4
        }
      ],
      "scoring": [
        {
          "range": [
            0,
            2
          ],
          "label": "Немає ТД",
          "color": "#00ff41",
          "action": "Повторити через 6–12 міс."
        },
        {
          "range": [
            3,
            9
          ],
          "label": "Мінімальна/Легка ТД",
          "color": "#ffcc00",
          "action": "↓ дозу АП. Розглянути клозапін/кветіапін. Вальбеназін (Ingrezza®) або деутетрабеназін (Austedo®)."
        },
        {
          "range": [
            10,
            20
          ],
          "label": "Помірна ТД",
          "color": "#ff8800",
          "action": "Замінити АП. Вальбеназін 40→80 мг/день або деутетрабеназін 6→24 мг×2р/день."
        },
        {
          "range": [
            21,
            40
          ],
          "label": "Тяжка ТД",
          "color": "#ff003c",
          "action": "НЕВІДКЛАДНА заміна АП. Вальбеназін/деутетрабеназін. Консультація невролога. ⚠ ТД може бути НЕЗВОРОТНОЮ."
        }
      ]
