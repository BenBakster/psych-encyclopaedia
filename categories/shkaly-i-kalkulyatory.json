          "action": "ОРИТ. Агрессивная седация. Loading dose диазепама. Исключить Вернике."
        }
      ],
      "labels": [
        "Шкала 0–7 для каждого пункта (кроме ориентировки: 0–4)"
      ]
    },
    "lastUpdated": "2026-04-03",
    "sources": []
  },
  {
    "id": "calc_audit",
    "cmd_alias": "audit",
    "type": "calculator",
    "category": "Шкалы и Калькуляторы",
    "title": "AUDIT: Скрининг алкогольной проблемы",
    "tags": [
      "шкала",
      "алкоголь",
      "скрининг",
      "AUDIT",
      "калькулятор"
    ],
    "related": [
      "alcohol_dependency",
      "calc_ciwa"
    ],
    "description": "Alcohol Use Disorders Identification Test. ВОЗ, 10 вопросов. Скрининг опасного и вредного употребления алкоголя.",
    "calculator": {
      "calcType": "scale",
      "items": [
        {
          "id": "a1",
          "text": "Как часто вы пьёте алкоголь?",
          "max": 4
        },
        {
          "id": "a2",
          "text": "Сколько стандартных доз в типичный день?",
          "max": 4
        },
        {
          "id": "a3",
          "text": "Как часто ≥6 доз за раз?",
          "max": 4
        },
        {
          "id": "a4",
          "text": "Как часто не могли остановиться?",
          "max": 4
        },
        {
          "id": "a5",
          "text": "Как часто не выполняли обычных дел?",
          "max": 4
        },
        {
          "id": "a6",
          "text": "Как часто нужно было опохмелиться?",
          "max": 4
        },
        {
          "id": "a7",
          "text": "Как часто чувство вины после выпивки?",
          "max": 4
        },
        {
          "id": "a8",
          "text": "Как часто не помнили, что было?",
          "max": 4
        },
        {
          "id": "a9",
          "text": "Травмы, связанные с алкоголем?",
          "max": 4
        },
        {
          "id": "a10",
          "text": "Кто-либо советовал пить меньше?",
          "max": 4
        }
      ],
      "scoring": [
        {
          "range": [
            0,
            7
          ],
          "label": "Низкий риск",
          "color": "#00ff41",
          "action": "Краткое информирование. Повторить через 1 год."
        },
        {
          "range": [
            8,
            15
          ],
          "label": "Опасное употребление",
          "color": "#ffcc00",
          "action": "Краткая интервенция. Мотивационное консультирование."
        },
        {
          "range": [
            16,
            19
          ],
          "label": "Вредное употребление",
          "color": "#ff8800",
          "action": "Краткая интервенция + мониторинг. Рассмотреть направление к наркологу."
        },
        {
          "range": [
            20,
            40
          ],
          "label": "Возможная зависимость",
          "color": "#ff003c",
          "action": "Направление к специалисту. Детоксикация. ЗТ/реабилитация."
        }
      ],
      "labels": [
        "0 — Никогда, 1 — Раз в мес или реже, 2 — 2–4 р/мес, 3 — 2–3 р/нед, 4 — ≥4 р/нед"
      ]
    },
    "lastUpdated": "2026-04-03",
    "sources": []
  },
