          "max": 4
        },
        {
          "id": "y2",
          "text": "↑ МОТОРНА АКТИВНІСТЬ / ЕНЕРГІЯ (жестикуляція, гіперактивність)",
          "max": 4
        },
        {
          "id": "y3",
          "text": "СЕКСУАЛЬНИЙ ІНТЕРЕС (↑ лібідо, гіперсексуальна поведінка)",
          "max": 4
        },
        {
          "id": "y4",
          "text": "ПОРУШЕННЯ СНУ (↓ потреби у сні)",
          "max": 4
        },
        {
          "id": "y5",
          "text": "ДРАТІВЛИВІСТЬ (×2: 0-2-4-6-8) — нетерплячість, ворожість, агресивність",
          "max": 8
        },
        {
          "id": "y6",
          "text": "МОВЛЕННЯ (×2: 0-2-4-6-8) — темп, тиск мовлення, нестримність",
          "max": 8
        },
        {
          "id": "y7",
          "text": "РОЗЛАДИ МИСЛЕННЯ — тангенціальність, зістрибування ідей",
          "max": 4
        },
        {
          "id": "y8",
          "text": "ЗМІСТ МИСЛЕННЯ (×2: 0-2-4-6-8) — грандіозність, параноїдність, маячення",
          "max": 8
        },
        {
          "id": "y9",
          "text": "АГРЕСИВНА ПОВЕДІНКА (×2: 0-2-4-6-8) — руйнування, загрози, насильство",
          "max": 8
        },
        {
          "id": "y10",
          "text": "ЗОВНІШНІЙ ВИГЛЯД — яскравий одяг, дезорганізація",
          "max": 4
        },
        {
          "id": "y11",
          "text": "ІНСАЙТ (0=повний, 4=відсутній)",
          "max": 4
        }
      ],
      "scoring": [
        {
          "range": [
            0,
            7
          ],
          "label": "Ремісія",
          "color": "#00ff41",
          "action": "Еутимія. Продовжити профілактику."
        },
        {
          "range": [
            8,
            12
          ],
          "label": "Мінімальні симптоми",
          "color": "#80ff80",
          "action": "Субсиндромальна. Перевірити комплаєнс, рівень нормотиміка."
