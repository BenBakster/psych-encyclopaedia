  {
    "id": "calc_cssrs",
    "cmd_alias": "cssrs",
    "type": "calculator",
    "category": "Шкалы и Калькуляторы",
    "title": "C-SSRS: Колумбійська шкала суїцидального ризику (скринінг)",
    "tags": [
      "суїцид",
      "скринінг",
      "C-SSRS",
      "ризик",
      "ургентне",
      "шкала"
    ],
    "related": [
      "alg_suicide",
      "law_kk_medical_liability",
      "calc_phq9"
    ],
    "description": "Columbia Suicide Severity Rating Scale — Screener. «Так» на пп.3–6 → ВИСОКИЙ РИЗИК → невідкладна оцінка. «Так» на пп.1–2 → ідеація без плану, мониторинг.",
    "calculator": {
      "calcType": "scale",
      "labels": [
        "0 — Ні",
        "1 — Так"
      ],
      "items": [
        {
          "id": "c1",
          "text": "Чи бажали Ви бути мертвим або заснути і не прокинутись?",
          "max": 1
        },
        {
          "id": "c2",
          "text": "Чи мали Ви думки про те, щоб покінчити з життям?",
          "max": 1
        },
        {
          "id": "c3",
          "text": "Чи думали Ви про те, ЯК це зробити (метод)?",
          "max": 1
        },
        {
          "id": "c4",
          "text": "Чи мали Ви ці думки з НАМІРОМ діяти?",
          "max": 1
        },
        {
          "id": "c5",
          "text": "Чи розробили Ви деталі плану і маєте НАМІР його здійснити?",
          "max": 1
        },
        {
          "id": "c6",
          "text": "Чи робили Ви БУДЬ-ЩО для реалізації (підготовчі дії, спроба)?",
          "max": 1
        }
      ],
      "scoring": [
        {
          "range": [
            0,
            0
          ],
          "label": "Немає ідеації",
          "color": "#00ff41",
          "action": "Рутинний моніторинг."
        },
        {
          "range": [
            1,
            2
          ],
          "label": "Пасивна ідеація (пп.1–2)",
          "color": "#ffcc00",
          "action": "Моніторинг. Оцінити захисні фактори. Повторити через 2 тижні. Розглянути АД."
        },
        {
          "range": [
            3,
            4
          ],
          "label": "⚠ Активна ідеація з методом/наміром",
          "color": "#ff8800",
          "action": "ВИСОКИЙ РИЗИК. Невідкладна психіатрична оцінка. Обмеження доступу до засобів. Розглянути госпіталізацію."
        },
        {
          "range": [
            5,
            6
          ],
          "label": "🔴 План + дії / спроба",
          "color": "#ff003c",
          "action": "КРИТИЧНИЙ РИЗИК. Негайна госпіталізація. Постійний нагляд."
        }
      ]
    },
    "lastUpdated": "2026-04-03",
    "sources": []
  },
  {
    "id": "calc_cage",
    "cmd_alias": "cage",
    "type": "calculator",
    "category": "Шкалы и Калькуляторы",
    "title": "CAGE: експрес-скринінг алкогольної залежності",
    "tags": [
      "алкоголь",
      "скринінг",
      "CAGE",
      "залежність",
      "шкала"
    ],
    "related": [
      "calc_audit",
      "alcohol_dependency",
      "benzo_withdrawal"
    ],
    "description": "4 питання. ≥2 «Так» — чутливість 93%, специфічність 76% (Ewing, JAMA 1984).",
    "calculator": {
      "calcType": "scale",
      "labels": [
        "0 — Ні",
        "1 — Так"
      ],
      "items": [
        {
          "id": "cage1",
          "text": "C — Cut down: Чи відчували, що потрібно СКОРОТИТИ вживання?",
          "max": 1
        },
        {
          "id": "cage2",
          "text": "A — Annoyed: Чи ДРАТУВАЛИ Вас люди, критикуючи вживання?",
          "max": 1
        },
        {
          "id": "cage3",
          "text": "G — Guilty: Чи відчували ПРОВИНУ через вживання алкоголю?",
          "max": 1
        },
        {
          "id": "cage4",
          "text": "E — Eye-opener: Чи вживали алкоголь ЗРАНКУ для зняття похмілля?",
          "max": 1
        }
      ],
      "scoring": [
        {
          "range": [
            0,
            0
          ],
          "label": "Негативний скринінг",
          "color": "#00ff41",
          "action": "Алкогольна залежність малоймовірна."
        },
        {
          "range": [
            1,
            1
          ],
          "label": "Підозра",
          "color": "#ffcc00",
          "action": "Можливе проблемне вживання. Провести AUDIT."
        },
        {
          "range": [
            2,
            3
          ],
          "label": "Клінічно значущий",
          "color": "#ff8800",
          "action": "Висока ймовірність залежності (Se 93%). Детальна наркологічна оцінка."
        },
        {
          "range": [
            4,
            4
          ],
          "label": "Високий ризик",
          "color": "#ff003c",
          "action": "Залежність вельми ймовірна. Наркологічна оцінка + лабораторно (ГГТ, CDT, MCV, АЛТ/АСТ)."
        }
      ]
    },
    "lastUpdated": "2026-04-03",
    "sources": []
  },
  {
    "id": "calc_barnes",
    "cmd_alias": "barnes",
    "type": "calculator",
