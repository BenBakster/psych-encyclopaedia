    "description": "Barnes Akathisia Rating Scale. Спостерігати ≥2 хв сидячи + ≥2 хв стоячи. Критично при арипипразолі (до 25% акатизії).",
    "calculator": {
      "calcType": "scale",
      "labels": "0 — Відсутня | 1 — Легка | 2 — Помірна | 3 — Виражена",
      "items": [
        {
          "id": "ba1",
          "text": "ОБ'ЄКТИВНА: рухове занепокоєння (переступання, розгойдування, нездатність сидіти нерухомо)",
          "max": 3
        },
        {
          "id": "ba2",
          "text": "СУБ'ЄКТИВНЕ усвідомлення: внутрішнє занепокоєння, потреба рухатись",
          "max": 3
        },
        {
          "id": "ba3",
          "text": "СУБ'ЄКТИВНИЙ дистрес: наскільки занепокоєння ТУРБУЄ пацієнта",
          "max": 3
        },
        {
          "id": "ba4",
          "text": "ГЛОБАЛЬНА оцінка клініциста: 0=немає, 1=сумнівна, 2=легка, 3=помірна, 4=виражена, 5=тяжка",
          "max": 5
        }
      ],
      "scoring": [
        {
          "range": [
            0,
            1
          ],
          "label": "Відсутня / Сумнівна",
          "color": "#00ff41",
          "action": "Повторити при зміні дозі АП."
        },
        {
          "range": [
            2,
            5
          ],
          "label": "Легка акатизія",
          "color": "#ffcc00",
          "action": "↓ дозу АП. Пропранолол 20–60 мг. Моніторинг."
        },
        {
          "range": [
            6,
            9
          ],
          "label": "Помірна акатизія",
          "color": "#ff8800",
          "action": "Пропранолол 40–80 мг, міртазапін або бензодіазепін. Розглянути зміну АП."
        },
        {
          "range": [
            10,
            14
          ],
          "label": "Тяжка акатизія",
          "color": "#ff003c",
          "action": "⚠ ↑ суїцидального ризику! Змінити АП (кветіапін/клозапін). Пропранолол + бензодіазепін."
        }
      ]
    },
    "lastUpdated": "2026-04-03",
    "sources": []
  },
  {
    "id": "calc_sas",
    "cmd_alias": "sas",
    "type": "calculator",
    "category": "Шкалы и Калькуляторы",
    "title": "SAS: Шкала Сімпсона-Ангуса (ЕПС / паркінсонізм)",
    "tags": [
      "ЕПС",
      "ригідність",
      "тремор",
