[
  {
    "id": "calc_phq9",
    "cmd_alias": "phq9",
    "type": "calculator",
    "category": "Шкалы и Калькуляторы",
    "title": "PHQ-9: Шкала депрессии",
    "tags": [
      "шкала",
      "депрессия",
      "скрининг",
      "PHQ-9",
      "калькулятор"
    ],
    "related": [
      "f32_criteria",
      "syndromology_depressive",
      "flowchart_ad"
    ],
    "description": "Patient Health Questionnaire-9. Скрининг и мониторинг депрессии. Каждый пункт: 0–3 балла. За последние 2 недели.",
    "calculator": {
      "calcType": "scale",
      "items": [
        {
          "id": "q1",
          "text": "Сниженный интерес или удовольствие от деятельности",
          "max": 3
        },
        {
          "id": "q2",
          "text": "Подавленность, безнадёжность",
          "max": 3
        },
        {
          "id": "q3",
          "text": "Проблемы со сном (бессонница или гиперсомния)",
          "max": 3
        },
        {
          "id": "q4",
          "text": "Усталость, упадок сил",
          "max": 3
        },
        {
          "id": "q5",
          "text": "Снижение аппетита или переедание",
          "max": 3
        },
        {
          "id": "q6",
          "text": "Чувство вины, никчёмности",
          "max": 3
        },
        {
          "id": "q7",
          "text": "Трудности концентрации",
          "max": 3
        },
        {
          "id": "q8",
          "text": "Заторможенность или ажитация (объективно)",
          "max": 3
        },
        {
          "id": "q9",
          "text": "Мысли о смерти или самоповреждении",
          "max": 3
        }
      ],
      "scoring": [
        {
          "range": [
            0,
            4
          ],
          "label": "Минимальная",
          "color": "#00ff41",
          "action": "Мониторинг."
        },
        {
          "range": [
            5,
            9
          ],
          "label": "Лёгкая",
          "color": "#80ff80",
          "action": "Наблюдение. Повторить PHQ-9 через 4 нед."
        },
        {
          "range": [
            10,
            14
          ],
          "label": "Умеренная",
          "color": "#ffcc00",
          "action": "Рассмотреть КПТ и/или АД."
        },
        {
          "range": [
            15,
            19
          ],
          "label": "Умеренно-тяжёлая",
          "color": "#ff8800",
          "action": "АД + психотерапия."
        },
        {
          "range": [
            20,
            27
          ],
          "label": "Тяжёлая",
          "color": "#ff003c",
          "action": "АД обязательно. При суицидальности — госпитализация."
        }
      ],
      "labels": [
        "0 — Никогда",
        "1 — Несколько дней",
        "2 — Более половины дней",
        "3 — Почти каждый день"
      ]
    },
    "lastUpdated": "2026-04-03",
    "sources": []
  },
  {
    "id": "calc_ciwa",
